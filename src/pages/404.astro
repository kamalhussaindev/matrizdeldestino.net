---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout
  title="Página no encontrada | Arcania"
  description="La página que buscas no existe o fue movida. Vuelve a Arcania para calcular tu Matriz del Destino, ver los 22 arcanos o leer nuestras guías."
>
  <div class="mx-auto flex max-w-xl flex-col items-center px-4 py-24 text-center sm:px-6">
    <h1 class="font-heading text-4xl font-bold text-ink sm:text-5xl">Página no encontrada</h1>
    <p class="mt-4 text-lg text-ink-muted">La página que buscas no existe o fue movida.</p>

    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <Button href="/matriz-del-destino/">Calcular mi Matriz del Destino →</Button>
      <Button href="/arcanos/" variant="secondary">Ver los 22 Arcanos →</Button>
      <Button href="/guias/" variant="secondary">Leer las Guías →</Button>
    </div>
  </div>
</BaseLayout>
