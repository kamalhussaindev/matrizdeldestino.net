---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SchemaFAQ from '../components/seo/SchemaFAQ.astro';
import SchemaSoftwareApp from '../components/seo/SchemaSoftwareApp.astro';
import Hero from '../components/content/Hero.astro';
import ValuePropCards from '../components/content/ValuePropCards.astro';
import ExampleResult from '../components/content/ExampleResult.astro';
import BenefitsGrid from '../components/content/BenefitsGrid.astro';
import HowItWorks from '../components/content/HowItWorks.astro';
import Testimonials from '../components/content/Testimonials.astro';
import ArcanoDelDia from '../components/content/ArcanoDelDia.astro';
import FaqAccordion from '../components/content/FaqAccordion.astro';
import RelatedCalculators from '../components/content/RelatedCalculators.astro';
import BlogStrip from '../components/content/BlogStrip.astro';
import CtaEmailCapture from '../components/content/CtaEmailCapture';
import MatrixCalculator from '../components/calculator/MatrixCalculator';
import { homeFaq } from '../data/faq';
import { calculators } from '../data/calculators';

// The homepage already IS the matriz-del-destino experience, so exclude it here.
const relatedCalculators = calculators.filter((c) => c.slug !== 'matriz-del-destino');

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3)
  .map((post) => ({
    title: post.data.title,
    excerpt: post.data.metaDescription,
    href: `/blog/${post.slug}/`,
    heroImage: post.data.heroImage,
  }));
---

<BaseLayout
  title="Matriz del Destino: Calculadora Gratis Online | Arcania"
  description="Calcula tu Matriz del Destino gratis con tu fecha de nacimiento. Descubre tus 22 arcanos, tu propósito y energías al instante. Sin registro."
  preloadImage="/images/homepage/hero-calculadora-matriz-del-destino.webp"
>
  <SchemaFAQ slot="schema" qa={homeFaq} />
  <SchemaSoftwareApp
    slot="schema"
    name="Calculadora de la Matriz del Destino"
    description="Calculadora gratuita de la Matriz del Destino a partir de la fecha de nacimiento."
  />

  <Hero
    title="Calculadora de la Matriz del Destino"
    subtitle="Descubre tus 22 arcanos, tu propósito y tus energías al instante, a partir de tu fecha de nacimiento."
    backgroundImage="/images/homepage/hero-calculadora-matriz-del-destino.webp"
  >
    <MatrixCalculator client:visible />
  </Hero>

  <div class="pt-8">
    <ArcanoDelDia />
  </div>

  <ValuePropCards />
  <ExampleResult />
  <BenefitsGrid />
  <HowItWorks />
  <Testimonials />

  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h2 class="font-heading text-2xl font-bold text-ink sm:text-3xl">¿Qué es la Matriz del Destino?</h2>
    <div class="mt-4 flex flex-col gap-4 text-ink-muted">
      <p>
        La Matriz del Destino es un sistema de autoconocimiento creado en 2006 por la numeróloga rusa
        Natalia Ladini. Combina numerología, los 22 arcanos mayores del tarot y la energía de los
        chakras para construir un mapa simbólico —el octagrama— a partir de un único dato: tu fecha de
        nacimiento.
      </p>
      <p>
        El método reduce tu día, mes y año de nacimiento a números del 1 al 22 y los distribuye en las
        distintas posiciones del octagrama. Cada posición representa un aspecto distinto de tu vida —tu
        personalidad, tus talentos, tu propósito, tus relaciones y tu relación con el dinero— y se
        interpreta cruzando su significado con el del arcano que le corresponde.
      </p>
      <p>
        Si quieres profundizar en el origen del método y en cómo se calcula paso a paso, visita nuestra
        guía completa sobre <a href="/guias/que-es-la-matriz-del-destino/" class="font-medium text-primary hover:underline">qué es la Matriz del Destino</a>,
        o explora el significado de cada uno de los <a href="/arcanos/" class="font-medium text-primary hover:underline">22 arcanos mayores</a>.
      </p>
    </div>
  </section>

  <FaqAccordion qa={homeFaq} />
  <RelatedCalculators items={relatedCalculators} />
  <BlogStrip posts={latestPosts} />
  <CtaEmailCapture client:visible />
</BaseLayout>
