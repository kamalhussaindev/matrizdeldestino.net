---
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import SchemaBreadcrumb from '../../components/seo/SchemaBreadcrumb.astro';
import SchemaArticle from '../../components/seo/SchemaArticle.astro';
import Card from '../../components/ui/Card.astro';
import TableOfContents from '../../components/content/TableOfContents.astro';
import { readingTime } from '../../lib/readingTime';

const CONTENT_UPDATED = new Date('2026-07-09');

export async function getStaticPaths() {
  const guias = await getCollection('guias');
  return guias.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'guias'>;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const { title, metaDescription, author, relatedGuias, datePublished, heroImage } = entry.data;
const minutesToRead = readingTime(entry.body);

const ogImageCandidate = `/og/og-guia-${entry.slug}.png`;
const ogImagePath = fileURLToPath(new URL(`../../../public${ogImageCandidate}`, import.meta.url));
const ogImage = existsSync(ogImagePath) ? ogImageCandidate : '/og/default.png';

const allGuias = await getCollection('guias');
const relatedEntries = relatedGuias
  .map((slug) => allGuias.find((e) => e.slug === slug))
  .filter((e): e is CollectionEntry<'guias'> => Boolean(e));

const breadcrumbItems = [
  { label: 'Guías', href: '/guias/' },
  { label: title },
];
---

<BaseLayout
  title={`${title} | Arcania`}
  description={metaDescription}
  ogImage={ogImage}
  preloadImage={heroImage}
  showMobileStickyBar
>
  <SchemaBreadcrumb slot="schema" items={breadcrumbItems} />
  <SchemaArticle
    slot="schema"
    headline={title}
    description={metaDescription}
    datePublished={datePublished}
    dateModified={CONTENT_UPDATED}
  />

  <Breadcrumbs items={breadcrumbItems} />

  <article class="mx-auto max-w-3xl px-4 sm:px-6">
    {
      heroImage && (
        <Image
          src={heroImage}
          alt={`${title} — Guía Arcania`}
          width={1200}
          height={500}
          widths={[600, 900, 1200]}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 90vw, 1200px"
          loading="eager"
          fetchpriority="high"
          class="mb-6 aspect-[1200/500] w-full rounded-2xl object-cover"
        />
      )
    }

    <h1 class="font-heading text-4xl font-bold text-ink sm:text-5xl">{title}</h1>
    <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-ink-muted">
      <span>{author}</span>
      <span aria-hidden="true">·</span>
      <span>{minutesToRead}</span>
    </div>

    <a href="/matriz-del-destino/" class="mt-4 inline-block font-medium text-primary hover:underline">
      Calcula tu Matriz del Destino →
    </a>

    <TableOfContents headings={headings.filter((h) => h.depth === 2)} label="En esta guía:" />

    <div class="prose prose-headings:font-heading prose-headings:text-ink prose-p:text-ink-muted prose-a:text-primary mt-6 max-w-none">
      <Content />
    </div>

    {
      relatedEntries.length > 0 && (
        <section class="py-12">
          <h2 class="font-heading text-2xl font-bold text-ink">Guías relacionadas</h2>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            {relatedEntries.map((related) => (
              <Card href={`/guias/${related.slug}/`}>
                <h3 class="font-heading text-lg font-semibold text-ink">{related.data.title}</h3>
                <p class="mt-2 text-sm text-ink-muted">{related.data.metaDescription}</p>
              </Card>
            ))}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>
