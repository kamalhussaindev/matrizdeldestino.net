---
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import SchemaBreadcrumb from '../../components/seo/SchemaBreadcrumb.astro';
import SchemaArticle from '../../components/seo/SchemaArticle.astro';
import Badge from '../../components/ui/Badge.astro';
import { readingTime } from '../../lib/readingTime';

const CONTENT_UPDATED = new Date('2026-07-09');

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, metaDescription, publishDate, author, tags, heroImage } = entry.data;
const minutesToRead = readingTime(entry.body);

const ogImageCandidate = `/og/og-blog-${entry.slug}.png`;
const ogImagePath = fileURLToPath(new URL(`../../../public${ogImageCandidate}`, import.meta.url));
const ogImage = existsSync(ogImagePath) ? ogImageCandidate : '/og/default.png';

const dateFormatter = new Intl.DateTimeFormat('es', { dateStyle: 'long' });

const postURL = new URL(Astro.url.pathname, Astro.site).toString();
const whatsappShareURL = `https://wa.me/?text=${encodeURIComponent(`${title} ${postURL}`)}`;
const twitterShareURL = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(postURL)}`;

const breadcrumbItems = [
  { label: 'Blog', href: '/blog/' },
  { label: title },
];
---

<BaseLayout
  title={`${title} | Arcania`}
  description={metaDescription}
  ogType="article"
  ogImage={ogImage}
  preloadImage={heroImage}
  showMobileStickyBar
>
  <SchemaBreadcrumb slot="schema" items={breadcrumbItems} />
  <SchemaArticle
    slot="schema"
    headline={title}
    description={metaDescription}
    datePublished={publishDate}
    dateModified={CONTENT_UPDATED}
    authorName={author}
  />

  <Breadcrumbs items={breadcrumbItems} />

  <article class="mx-auto max-w-3xl px-4 sm:px-6">
    {
      heroImage && (
        <Image
          src={heroImage}
          alt={`${title} — Blog Arcania`}
          width={1200}
          height={630}
          widths={[600, 900, 1200]}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 90vw, 1200px"
          loading="eager"
          fetchpriority="high"
          class="mb-6 aspect-[1200/630] w-full rounded-2xl object-cover"
        />
      )
    }

    <h1 class="font-heading text-4xl font-bold text-ink sm:text-5xl">{title}</h1>
    <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-ink-muted">
      <Image
        src="/images/team/equipo-arcania-numerologia-espiritual.webp"
        alt="Equipo Arcania"
        width={40}
        height={40}
        loading="lazy"
        class="rounded-full"
      />
      <span>{author}</span>
      <span aria-hidden="true">·</span>
      <time datetime={publishDate.toISOString()}>{dateFormatter.format(publishDate)}</time>
      <span aria-hidden="true">·</span>
      <span>{minutesToRead}</span>
    </div>
    {
      tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <Badge variant="default">{tag}</Badge>
          ))}
        </div>
      )
    }

    <div class="prose prose-headings:font-heading prose-headings:text-ink prose-p:text-ink-muted prose-a:text-primary mt-6 max-w-none">
      <Content />
    </div>

    <a href="/matriz-del-destino/" class="mt-8 inline-block font-medium text-primary hover:underline">
      Calcula tu Matriz del Destino →
    </a>

    <div class="mt-8 flex flex-col gap-3 border-t border-surface-alt pt-8">
      <p class="text-sm font-medium text-ink">¿Te resultó útil? Compártelo:</p>
      <div class="flex flex-wrap gap-2">
        <a
          href={whatsappShareURL}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full border border-surface-alt px-4 py-2 text-sm font-medium text-ink hover:border-primary hover:text-primary"
        >
          WhatsApp
        </a>
        <a
          href={twitterShareURL}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full border border-surface-alt px-4 py-2 text-sm font-medium text-ink hover:border-primary hover:text-primary"
        >
          X
        </a>
        <button
          type="button"
          id="copy-link-button"
          class="rounded-full border border-surface-alt px-4 py-2 text-sm font-medium text-ink hover:border-primary hover:text-primary"
        >
          Copiar enlace
        </button>
      </div>
    </div>

    <div class="mt-8 flex flex-col gap-4 rounded-2xl border-l-4 border-accent bg-surface-alt p-6 sm:flex-row sm:items-start">
      <Image
        src="/images/team/equipo-arcania-numerologia-espiritual.webp"
        alt="Equipo Arcania"
        width={64}
        height={64}
        loading="lazy"
        class="h-16 w-16 shrink-0 rounded-full object-cover"
      />
      <div>
        <p class="font-heading text-base font-semibold text-ink">Equipo Arcania</p>
        <p class="mt-2 text-sm text-ink-muted">
          Somos un equipo apasionado por el autoconocimiento y la numerología espiritual. Combinamos el método de
          la Matriz del Destino con interpretaciones accesibles para ayudarte a descubrir tu propósito de vida.
        </p>
        <div class="mt-3 flex flex-wrap gap-4 text-sm font-medium">
          <a href="/metodo/" class="text-primary hover:underline">
            Conoce nuestro método →
          </a>
          <a href="/sobre-nosotros/" class="text-primary hover:underline">
            Sobre nosotros →
          </a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  const button = document.getElementById('copy-link-button');
  button?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(window.location.href);
    const original = button.textContent;
    button.textContent = '¡Enlace copiado!';
    setTimeout(() => {
      button.textContent = original;
    }, 2000);
  });
</script>
