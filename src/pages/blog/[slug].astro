---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import SchemaBreadcrumb from '../../components/seo/SchemaBreadcrumb.astro';
import SchemaArticle from '../../components/seo/SchemaArticle.astro';
import Badge from '../../components/ui/Badge.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, metaDescription, publishDate, author, tags } = entry.data;

const dateFormatter = new Intl.DateTimeFormat('es', { dateStyle: 'long' });

const breadcrumbItems = [
  { label: 'Blog', href: '/blog/' },
  { label: title },
];
---

<BaseLayout title={`${title} | Arcania`} description={metaDescription} ogType="article">
  <SchemaBreadcrumb slot="schema" items={breadcrumbItems} />
  <SchemaArticle slot="schema" headline={title} description={metaDescription} datePublished={publishDate} authorName={author} />

  <Breadcrumbs items={breadcrumbItems} />

  <article class="mx-auto max-w-3xl px-4 sm:px-6">
    <h1 class="font-heading text-4xl font-bold text-ink sm:text-5xl">{title}</h1>
    <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-ink-muted">
      <span>{author}</span>
      <span aria-hidden="true">·</span>
      <time datetime={publishDate.toISOString()}>{dateFormatter.format(publishDate)}</time>
    </div>
    {
      tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <Badge variant="default">{tag}</Badge>
          ))}
        </div>
      )
    }

    <div class="prose prose-headings:font-heading prose-headings:text-ink prose-p:text-ink-muted prose-a:text-primary mt-6 max-w-none">
      <Content />
    </div>

    <a href="/matriz-del-destino/" class="mt-8 inline-block font-medium text-primary hover:underline">
      Calcula tu Matriz del Destino →
    </a>
  </article>
</BaseLayout>
