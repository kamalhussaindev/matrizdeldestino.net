---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import SchemaBreadcrumb from '../components/seo/SchemaBreadcrumb.astro';
import Card from '../components/ui/Card.astro';

const breadcrumbItems = [{ label: 'Contacto' }];
---

<BaseLayout
  title="Contacto | Arcania"
  description="Escríbenos con tus preguntas, sugerencias o comentarios sobre la Matriz del Destino y nuestras calculadoras."
>
  <SchemaBreadcrumb slot="schema" items={breadcrumbItems} />

  <Breadcrumbs items={breadcrumbItems} />

  <article class="mx-auto max-w-2xl px-4 pb-16 sm:px-6">
    <h1 class="font-heading text-4xl font-bold text-ink sm:text-5xl">Contacto</h1>
    <p class="mt-4 text-lg text-ink-muted">
      ¿Tienes preguntas sobre tu resultado, sugerencias para el sitio o encontraste algo que no
      funciona como debería? Escríbenos, leemos todos los mensajes.
    </p>

    <Card class="mt-8">
      <h2 class="font-heading text-lg font-semibold text-ink">Correo electrónico</h2>
      <p class="mt-2 text-ink-muted">
        <a href="mailto:hola@matrizdeldestino.com" class="font-medium text-primary hover:underline">
          hola@matrizdeldestino.com
        </a>
      </p>
      <p class="mt-4 text-sm text-ink-muted">
        Respondemos en un plazo de 2 a 3 días hábiles. Si tu consulta es sobre cómo interpretar una
        posición específica de tu matriz, cuéntanos qué posición y qué arcano te salió para poder
        ayudarte mejor.
      </p>
    </Card>
  </article>
</BaseLayout>
