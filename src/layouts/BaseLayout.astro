---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SEOHead from '../components/seo/SEOHead.astro';
import SchemaOrganization from '../components/seo/SchemaOrganization.astro';
import SchemaWebSite from '../components/seo/SchemaWebSite.astro';
import Analytics from '../components/seo/Analytics.astro';
import MobileStickyBar from '../components/content/MobileStickyBar.astro';

export interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  showMobileStickyBar?: boolean;
  preloadImage?: string;
}

const {
  title,
  description,
  canonicalPath,
  ogImage,
  ogType,
  showMobileStickyBar = false,
  preloadImage,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/fraunces-700.woff2" as="font" type="font/woff2" crossorigin />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
    <noscript>
      <style>
        img[loading='lazy'] {
          opacity: 1;
        }
      </style>
    </noscript>

    <SEOHead
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      ogImage={ogImage}
      ogType={ogType}
    />
    <SchemaOrganization />
    <SchemaWebSite />
    <Analytics />

    <slot name="schema" />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#contenido" class="skip-link">Saltar al contenido</a>
    <Header />
    <main id="contenido" class:list={['flex-1', { 'pb-20 md:pb-0': showMobileStickyBar }]}>
      <slot />
    </main>
    <Footer />
    {showMobileStickyBar && <MobileStickyBar />}

    <script>
      document.querySelectorAll('img[loading="lazy"]').forEach((img) => {
        const el = img as HTMLImageElement;
        if (el.complete) el.classList.add('loaded');
        else el.addEventListener('load', () => el.classList.add('loaded'));
      });
    </script>
  </body>
</html>
