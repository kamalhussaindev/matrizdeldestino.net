---
import { calculate } from '../../lib/matrix/calculate';
import MatrixChart from '../calculator/MatrixChart';

// A fixed sample date, purely illustrative — not tied to any real user.
// Rendered with no client: directive, so Astro emits static HTML for this
// chart and ships zero extra client JS; it's decorative only.
const sample = calculate({ day: 10, month: 10, year: 1990 });
---

<section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
  <h2 class="text-center font-heading text-2xl font-bold text-ink sm:text-3xl">Así se ve tu resultado</h2>
  <p class="mx-auto mt-3 max-w-xl text-center text-ink-muted">
    Un ejemplo ilustrativo del octagrama que obtendrás con tu propia fecha de nacimiento.
  </p>
  {
    /*
      MatrixChart renders real <button> elements even without a client:
      directive, so aria-hidden alone would hide them from assistive tech
      while leaving them reachable by keyboard Tab (a real WCAG failure —
      caught by an axe-core audit). `inert` correctly removes the whole
      subtree from both the accessibility tree and the tab order.
    */
  }
  <div class="pointer-events-none mt-8" inert>
    <MatrixChart positions={sample.positions} activeKey={null} onSelect={() => {}} />
  </div>
</section>
