---
import Card from '../ui/Card.astro';
import Icon from '../ui/Icon.astro';

const items = [
  {
    icon: 'sparkle' as const,
    title: 'Autoconocimiento',
    body: 'Descubre tu personalidad, tus talentos y tu propósito a partir de un mapa único calculado con tu fecha de nacimiento.',
  },
  {
    icon: 'compass' as const,
    title: '22 Arcanos',
    body: 'Cada posición de tu matriz se interpreta cruzando su significado con el de uno de los 22 arcanos mayores del tarot.',
  },
  {
    icon: 'check' as const,
    title: 'Gratis',
    body: 'El cálculo completo de tu matriz es 100% gratuito, sin registro y sin límite de usos.',
  },
];
---

<section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
  <h2 class="sr-only">Por qué usar Arcania</h2>
  <div class="grid gap-6 sm:grid-cols-3">
    {
      items.map((item) => (
        <Card class="text-center">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-surface-alt text-primary">
            <Icon name={item.icon} class="h-6 w-6" />
          </div>
          <h3 class="mt-4 font-heading text-lg font-semibold text-ink">{item.title}</h3>
          <p class="mt-2 text-sm text-ink-muted">{item.body}</p>
        </Card>
      ))
    }
  </div>
</section>
