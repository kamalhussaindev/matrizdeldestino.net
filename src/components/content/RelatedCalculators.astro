---
import Card from '../ui/Card.astro';
import Icon from '../ui/Icon.astro';
import type { Props as IconProps } from '../ui/Icon.astro';

export interface Props {
  items: { label: string; description: string; href: string; icon: IconProps['name'] }[];
  heading?: string;
}

const { items, heading = 'Calculadoras relacionadas' } = Astro.props;
---

<section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
  <h2 class="text-center font-heading text-2xl font-bold text-ink sm:text-3xl">{heading}</h2>
  <div class="mt-10 grid gap-6 sm:grid-cols-2">
    {
      items.map((item) => (
        <Card href={item.href} class="flex items-start gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-surface-alt text-primary">
            <Icon name={item.icon} class="h-5 w-5" />
          </div>
          <div>
            <h3 class="font-heading text-lg font-semibold text-ink">{item.label}</h3>
            <p class="mt-1 text-sm text-ink-muted">{item.description}</p>
          </div>
        </Card>
      ))
    }
  </div>
  <p class="mt-8 text-center">
    <a href="/calculadoras/" class="font-medium text-primary hover:underline">
      Ver todas las calculadoras →
    </a>
  </p>
</section>
