---
export interface Props {
  numbers?: number[];
}

// Default teaser set for pages that just want a generic "explore the
// arcana" sampler (e.g. the calculator deep page). Arcana detail pages pass
// their own `relatedArcanos` frontmatter instead.
const { numbers = [1, 6, 9, 13, 17, 20] } = Astro.props;
---

<section class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6">
  <h2 class="font-heading text-2xl font-bold text-ink sm:text-3xl">Explora los 22 arcanos</h2>
  <p class="mx-auto mt-3 max-w-xl text-ink-muted">
    Cada posición de tu matriz está habitada por uno de los 22 arcanos mayores. Profundiza en su significado.
  </p>
  <div class="mt-8 flex flex-wrap justify-center gap-3">
    {
      numbers.map((n) => (
        <a
          href={`/arcanos/${n}/`}
          class="flex h-12 w-12 items-center justify-center rounded-full border-2 border-primary font-heading font-bold text-primary hover:bg-primary hover:text-white"
        >
          {n}
        </a>
      ))
    }
  </div>
  <a href="/arcanos/" class="mt-6 inline-block font-medium text-primary hover:underline">
    Ver todos los arcanos →
  </a>
</section>
