---
import { Image } from 'astro:assets';

export interface Props {
  title: string;
  subtitle: string;
  backgroundImage?: string;
}

const { title, subtitle, backgroundImage } = Astro.props;
---

<section class="relative overflow-hidden px-4 pb-4 pt-12 text-center sm:px-6 sm:pt-16">
  {
    backgroundImage && (
      <>
        <Image
          src={backgroundImage}
          alt="Calculadora de la Matriz del Destino — octagrama con 22 arcanos"
          width={1920}
          height={900}
          widths={[768, 1280, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
          class="absolute inset-x-0 top-0 -z-20 h-[620px] w-full object-cover sm:h-[680px]"
        />
        <div class="absolute inset-x-0 top-0 -z-10 h-[620px] bg-gradient-to-b from-primary-dark/70 via-primary-dark/65 to-primary-dark/0 sm:h-[680px]" />
      </>
    )
  }
  <div class="relative mx-auto max-w-3xl">
    <h1 class={`font-heading text-4xl font-bold sm:text-5xl ${backgroundImage ? 'text-white' : 'text-ink'}`}>
      {title}
    </h1>
    <p class={`mx-auto mt-4 max-w-xl text-lg ${backgroundImage ? 'text-white/90' : 'text-ink-muted'}`}>
      {subtitle}
    </p>
    <div class="mt-8">
      <slot />
    </div>
    {
      backgroundImage && (
        <p class="mt-5 flex justify-center">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-primary px-3 py-1 text-xs font-medium text-accent">
            ✨ Más de 50,000 personas han descubierto su propósito
          </span>
        </p>
      )
    }
  </div>
</section>
