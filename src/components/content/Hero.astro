---
export interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<section class="mx-auto max-w-3xl px-4 pb-4 pt-12 text-center sm:px-6 sm:pt-16">
  <h1 class="font-heading text-4xl font-bold text-ink sm:text-5xl">{title}</h1>
  <p class="mx-auto mt-4 max-w-xl text-lg text-ink-muted">{subtitle}</p>
  <div class="mt-8">
    <slot />
  </div>
</section>
