---
import Accordion from '../ui/Accordion';
import type { FaqItem } from '../../data/faq';

export interface Props {
  heading?: string;
  qa: FaqItem[];
}

const { heading = 'Preguntas frecuentes', qa } = Astro.props;
---

<section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
  <h2 class="text-center font-heading text-2xl font-bold text-ink sm:text-3xl">{heading}</h2>
  <div class="mt-8 rounded-2xl border border-surface-alt bg-white px-2">
    {
      qa.map((item) => (
        <Accordion title={item.question} client:visible>
          {item.answer}
        </Accordion>
      ))
    }
  </div>
</section>
