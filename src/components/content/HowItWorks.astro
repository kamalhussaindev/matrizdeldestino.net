---
const steps = [
  {
    title: 'Ingresa tu fecha',
    body: 'Escribe tu fecha de nacimiento en formato DD/MM/AAAA. El nombre es opcional.',
  },
  {
    title: 'Cálculo instantáneo',
    body: 'Calculamos tu octagrama completo en tu propio navegador, sin esperas ni envíos a servidores.',
  },
  {
    title: 'Interpretación personalizada',
    body: 'Explora cada posición y descubre qué arcano la habita y qué significa para tu vida.',
  },
];
---

<section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
  <h2 class="text-center font-heading text-2xl font-bold text-ink sm:text-3xl">Cómo funciona</h2>
  <ol class="mt-10 grid gap-8 sm:grid-cols-3">
    {
      steps.map((step, index) => (
        <li class="text-center">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-primary font-heading text-lg font-bold text-white">
            {index + 1}
          </div>
          <h3 class="mt-4 font-heading text-lg font-semibold text-ink">{step.title}</h3>
          <p class="mt-2 text-sm text-ink-muted">{step.body}</p>
        </li>
      ))
    }
  </ol>
</section>
