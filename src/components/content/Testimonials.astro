---
interface Testimonial {
  quote: string;
  name: string;
  country: string;
}

const testimonials: Testimonial[] = [
  {
    quote:
      'Nunca pensé que mi fecha de nacimiento pudiera revelar tanto sobre mi propósito. La lectura del Arcano 6 en mi centro fue increíblemente precisa.',
    name: 'María G.',
    country: 'México',
  },
  {
    quote:
      'Calculé mi matriz y la de mi pareja. La sección de compatibilidad nos ayudó a entender por qué tenemos ciertos conflictos recurrentes.',
    name: 'Carlos R.',
    country: 'Argentina',
  },
  {
    quote:
      'La interpretación de mi cola kármica fue lo más revelador. Entendí patrones que se repiten en mi vida desde hace años.',
    name: 'Laura M.',
    country: 'España',
  },
];
---

<section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
  <h2 class="text-center font-heading text-2xl font-bold text-ink sm:text-3xl">Lo que dicen quienes ya calcularon su matriz</h2>
  <div class="mt-10 grid gap-6 sm:grid-cols-3">
    {
      testimonials.map((t) => (
        <figure class="rounded-2xl border border-primary/15 bg-surface-alt p-6 shadow-sm">
          <span class="inline-flex items-center gap-0.5 rounded-full bg-primary px-2.5 py-1 text-xs text-accent" aria-hidden="true">
            {'★★★★★'}
          </span>
          <blockquote class="mt-4 text-sm text-ink-muted">"{t.quote}"</blockquote>
          <figcaption class="mt-4 text-sm font-semibold text-ink">
            {t.name} <span class="font-normal text-ink-muted">· {t.country}</span>
          </figcaption>
        </figure>
      ))
    }
  </div>
</section>
