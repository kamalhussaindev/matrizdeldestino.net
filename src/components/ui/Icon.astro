  menu: 'M4 6h16M4 12h16M4 18h16',
  close: 'M6 6l12 12M18 6L6 18',
  compass: 'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18zM15 9l-2 5-5 2 2-5 5-2z',
  heart:
    'M20.8 7.6c0-2.6-2.1-4.6-4.7-4.6-1.6 0-3 .8-3.9 2-.9-1.2-2.3-2-3.9-2-2.6 0-4.7 2-4.7 4.6 0 5.1 8.6 10.8 8.6 10.8s8.6-5.7 8.6-10.8z',
  coins:
    'M9 17a4 2.5 0 1 0 0-5 4 2.5 0 1 0 0 5zM13 14.5V16a4 2.5 0 0 1-8 0v-1.5M13 14.5V13a4 2.5 0 0 0-8 0v1.5M17 8.5a4 2.5 0 1 1-8 0 4 2.5 0 1 1 8 0zM17 8.5V10a4 2.5 0 0 1-3 2.4',
  infinity:
    'M8.5 8a4 4 0 1 0 0 8c2.5 0 3.5-1.8 5-4M15.5 16a4 4 0 1 0 0-8c-2.5 0-3.5 1.8-5 4',
  users:
    'M9 11a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7zM3 20c0-3.3 2.7-6 6-6s6 2.7 6 6M17 11a3 3 0 1 0 0-6M15.5 14c2.6.3 4.5 2.6 4.5 6',
  child:
    'M12 3a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM7 21v-5a5 5 0 0 1 10 0v5',
};
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={ariaHidden ? 'true' : undefined}
>
  <path d={paths[name]} />
</svg>
