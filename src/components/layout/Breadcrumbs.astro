---
// Visual breadcrumb trail only. BreadcrumbList JSON-LD is emitted separately
// by SchemaBreadcrumb.astro (Milestone 4) so schema stays decoupled from markup.
export interface Props {
  items: { label: string; href?: string }[];
}

const { items } = Astro.props;
---

<nav aria-label="Migas de pan" class="mx-auto max-w-6xl px-4 py-4 text-sm sm:px-6">
  <ol class="flex flex-wrap items-center gap-2 text-ink-muted">
    <li class="flex items-center gap-2">
      <a href="/" class="hover:text-primary">Inicio</a>
      <span aria-hidden="true">/</span>
    </li>
    {
      items.map((item, i) => (
        <li class="flex items-center gap-2">
          {item.href && i !== items.length - 1 ? (
            <a href={item.href} class="hover:text-primary">
              {item.label}
            </a>
          ) : (
            <span class="font-medium text-ink" aria-current="page">
              {item.label}
            </span>
          )}
          {i !== items.length - 1 && <span aria-hidden="true">/</span>}
        </li>
      ))
    }
  </ol>
</nav>
