---
// GA4 scaffold — off in dev, and inert in production unless a real
// measurement ID is configured. Dropping in a real ID later is one line:
// set PUBLIC_GA_MEASUREMENT_ID in the deploy environment (see .env.example).
// No ID is hardcoded here.
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const enabled = import.meta.env.PROD && Boolean(gaId);
---

{
  enabled && (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    </>
  )
}
